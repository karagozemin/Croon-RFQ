# =============================================================================
# CROON RFQ — Environment Configuration
# Copy to `.env` and fill in. NEVER commit your real .env.
# =============================================================================

# Demo-day safety net: flip the whole app between fake and live CAP.
#   mock -> MockCapClient (deterministic fake agents, no network, no keys needed)
#   live -> real CapClient (requires CROO CAP SDK + USDC-funded AA wallet).
CROON_CAP_MODE=mock

# Local SQLite database URL (SQLModel/SQLAlchemy format).
CROON_DATABASE_URL=sqlite:///croon.db

# HTTP server
CROON_HOST=127.0.0.1
CROON_PORT=8000

# Scheduler tick interval (seconds) — how often the in-process loop checks for
# standing orders that are due. NOT production cron; demo-grade only.
CROON_SCHEDULER_TICK_SECONDS=10

# --- Mini-RFQ engine tuning -------------------------------------------------
# Per-run RFQ timeout. If fewer than 1 valid quote returns in this window,
# the fallback provider is used (see README §Fallback).
CROON_RFQ_TIMEOUT_SECONDS=10

# Scoring weights (must be documented; see croon/scoring.py). Sum ~= 1.0.
CROON_W_PRICE=0.4
CROON_W_REP=0.35
CROON_W_SPEED=0.25

# =============================================================================
# LIVE mode only (CROON_CAP_MODE=live). Leave blank in mock mode.
# Confirmed against the official CROO Python SDK Reference (pip install croo-sdk).
# =============================================================================

# API key from the CROO Dashboard / Agent Store. Format: croo_sk_...
# Auth header X-SDK-Key. Required for live mode.
CROON_CROO_SDK_KEY=

# CROO API + WebSocket endpoints and the Base RPC (defaults shown).
CROON_CROO_API_URL=https://api.croo.network
CROON_CROO_WS_URL=wss://api.croo.network/ws
CROON_BASE_RPC_URL=https://mainnet.base.org

# Candidate roster for the mini-RFQ. The SDK has NO discovery primitive
# (agents/services are set up in the Agent Store), so we list Store services
# here. Quotes are DERIVED from listed_price_usdc / listed_eta_seconds (spec §4).
# JSON array; keep it on one line in .env.
# CROON_LIVE_CANDIDATES_JSON=[{"agent_id":"agent_alpha","name":"Alpha Analytics","service_id":"svc_...","category":"risk","listed_price_usdc":"0.12","listed_eta_seconds":40,"reputation":0.72},{"agent_id":"agent_beta","name":"Beta Insights","service_id":"svc_...","category":"risk","listed_price_usdc":"0.20","listed_eta_seconds":20,"reputation":0.91}]
CROON_LIVE_CANDIDATES_JSON=[]

# OUR base agent as the fallback provider (§7). Its Store service id.
CROON_FALLBACK_SERVICE_ID=
CROON_FALLBACK_AGENT_ID=base_listing_copy
CROON_FALLBACK_AGENT_NAME=CROON Fallback Provider

# PRECONDITION: CROON's AA wallet must be funded with USDC on Base BEFORE any
# live paid run, or pay_order fails with insufficient balance. The wallet is
# tied to your CROO account/API key (managed in the Dashboard).

