# =============================================================================
# CROON RFQ — Environment Configuration
# Copy to `.env` and fill in. NEVER commit your real .env.
# =============================================================================

# Demo-day safety net: flip the whole app between fake and live CAP.
#   mock -> MockCapClient (deterministic fake agents, no network, no keys needed)
#   live -> real CapClient (requires CROO CAP SDK + funded wallet). NOT wired yet.
CROON_CAP_MODE=mock

# Local SQLite database URL (SQLModel/SQLAlchemy format).
CROON_DATABASE_URL=sqlite:///croon.db

# HTTP server
CROON_HOST=127.0.0.1
CROON_PORT=8000

# Scheduler tick interval (seconds) — how often the in-process loop checks for
# standing orders that are due. NOT production cron; demo-grade only.
CROON_SCHEDULER_TICK_SECONDS=10

# --- Mini-RFQ engine tuning -------------------------------------------------
# Per-run RFQ timeout. If fewer than 1 valid quote returns in this window,
# the fallback provider is used (see README §Fallback).
CROON_RFQ_TIMEOUT_SECONDS=10

# Scoring weights (must be documented; see croon/scoring.py). Sum ~= 1.0.
CROON_W_PRICE=0.4
CROON_W_REP=0.35
CROON_W_SPEED=0.25

# --- LIVE mode only (leave blank in mock mode) ------------------------------
# TODO(step 4): confirm exact names/format against the official CROO CAP SDK docs
# before using. Do not invent values.
# CROON_CAP_API_KEY=
# CROON_AGENT_WALLET_PRIVATE_KEY=
# CROON_BASE_RPC_URL=
# CROON_USDC_CONTRACT_ADDRESS=
